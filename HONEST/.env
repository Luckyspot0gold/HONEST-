# .env

# ==========================================
# WALLET CONFIGURATION (x402 Hackathon)
# ==========================================
# Wallet 1: Deployer/Validator (10 AVAX)
DEPLOYER_PRIVATE_KEY=0xYOUR_WALLET_1_PRIVATE_KEY_HERE

# Wallet 2: Payment Receiver (2 AVAX)
RECEIVER_PRIVATE_KEY=0xYOUR_WALLET_2_PRIVATE_KEY_HERE

# Legacy (same as deployer for backward compatibility)
PRIVATE_KEY=0xYOUR_WALLET_1_PRIVATE_KEY_HERE

# ==========================================
# CONTRACT ADDRESSES (Will be filled after deployment)
# ==========================================
VITE_NFT_CONTRACT_ADDRESS=
VITE_X402_PAYMENT_CONTRACT_ADDRESS=

# ==========================================
# NETWORK CONFIGURATION
# ==========================================
VITE_NETWORK=fuji
VITE_CHAIN_ID=43113

# RPC URLs
VITE_FUJI_RPC=https://api.avax-test.network/ext/bc/C/rpc
VITE_AVALANCHE_RPC=https://api.avax.network/ext/bc/C/rpc

# ==========================================
# API KEYS
# ==========================================
SNOWTRACE_API_KEY=YOUR_SNOWTRACE_API_KEY
VITE_REALITY_PROTOCOL_API_KEY=rp_live_your_key_here

# ==========================================
# X402 CONFIGURATION
# ==========================================
VITE_X402_ENABLED=true
VITE_USDC_TOKEN_ADDRESS=0x5425890298aed601595a70AB815c96711a31Bc65  # Fuji USDC
# 1. Install dependencies
npm install

# 2. Create .env with your keys
echo "PRIVATE_KEY=0xyour_key_here" > .env
echo "SNOWTRACE_API_KEY=your_api_key" >> .env

# 3. Get testnet AVAX
# (Visit faucet.avax.network)

# 4. Deploy contract
npx hardhat run scripts/deploy.js --network fuji

# 5. Copy contract address to .env
echo "VITE_NFT_CONTRACT_ADDRESS=0xYOUR_CONTRACT_ADDRESS" >> .env

# 6. Done! 🎉
