=======================================
# WALLET CONFIGURATION
# ==========================================
# Your wallet private key (KEEP SECRET!)
PRIVATE_KEY=0x1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef

# ==========================================
# CONTRACT ADDRESSES
# ==========================================
# Your deployed NFT contract address
VITE_NFT_CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# Optional: Other contracts
VITE_TOKEN_CONTRACT_ADDRESS=0x...
VITE_ORACLE_CONTRACT_ADDRESS=0x...

# ==========================================
# API KEYS
# ==========================================
# Snowtrace API key (for contract verification)
SNOWTRACE_API_KEY=ABC123DEF456

# Reality Protocol API key
VITE_REALITY_PROTOCOL_API_KEY=rp_live_your_key_here

# Other API keys
VITE_COINGECKO_API_KEY=your_key_here
VITE_BINANCE_API_KEY=your_key_here

# ==========================================
# NETWORK CONFIGURATION
# ==========================================
# Which network to use (fuji, avalanche, ethereum)
VITE_NETWORK=fuji

# RPC URLs (optional - uses defaults if not provided)
VITE_AVALANCHE_RPC=https://api.avax.network/ext/bc/C/rpc
VITE_FUJI_RPC=https://api.avax-test.network/ext/bc/C/rpc

# ==========================================
# APPLICATION CONFIGURATION
# ==========================================
# Base URL for your API
VITE_API_BASE_URL=https://honestdemo.manus.space/api

# WebSocket URL
VITE_WS_URL=wss://honestdemo.manus.space/api/ws

# Frontend URL
VITE_APP_URL=https://honestdemo.manus.space

# ==========================================
# DEVELOPMENT FLAGS
# ==========================================
VITE_DEBUG_MODE=true
VITE_USE_MOCK_DATA=false
