### Go

```go
package main

import (
    "encoding/json"
    "fmt"
    "io"
    "net/http"
)

const (
    APIKey  = "rp_live_your_key_here"
    BaseURL = "https://honestdemo.manus.space/api"
)

type Eigenstate struct {
    Coherence  float64 `json:"coherence"`
    Decision   string  `json:"decision"`
    PhaseAngle float64 `json:"phase_angle"`
}

type EigenstateResponse struct {
    Status     string      `json:"status"`
    Asset      string      `json:"asset"`
    Eigenstate Eigenstate  `json:"eigenstate"`
}

func getEigenstate(asset string) (*EigenstateResponse, error) {
    url := fmt.Sprintf("%s/v1/eigenstate/%s?timeframe=1h", BaseURL, asset)
    
    req, err := http.NewRequest("GET", url, nil)
    if err != nil {
        return nil, err
    }
    
    req.Header.Set("Authorization", fmt.Sprintf("Bearer %s", APIKey))
    
    client := &http.Client{}
    resp, err := client.Do(req)
    if err != nil {
        return nil, err
    }
    defer resp.Body.Close()
    
    body, err := io.ReadAll(resp.Body)
    if err != nil {
        return nil, err
    }
    
    var result EigenstateResponse
    err = json.Unmarshal(body, &result)
    if err != nil {
        return nil, err
    }
    
    return &result, nil
}

func main() {
    btc, err := getEigenstate("BTC")
    if err != nil {
        fmt.Printf("Error: %v\n", err)
        return
    }
    
    fmt.Printf("BTC Coherence: %.3f\n", btc.Eigenstate.Coherence)
    fmt.Printf("Decision: %s\n", btc.Eigenstate.Decision)
    fmt.Printf("Phase Angle: %.1f°\n", btc.Eigenstate.PhaseAngle)
}
